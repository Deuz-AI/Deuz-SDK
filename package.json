{
  "name": "@deuz/core",
  "version": "0.0.0",
  "description": "Pure, web-first, multi-provider TypeScript AI SDK (Anthropic, OpenAI, xAI, Gemini).",
  "license": "MIT",
  "author": "U-C4N",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@10.9.0",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./anthropic": {
      "import": {
        "types": "./dist/anthropic.d.ts",
        "default": "./dist/anthropic.js"
      },
      "require": {
        "types": "./dist/anthropic.d.cts",
        "default": "./dist/anthropic.cjs"
      }
    },
    "./openai": {
      "import": {
        "types": "./dist/openai.d.ts",
        "default": "./dist/openai.js"
      },
      "require": {
        "types": "./dist/openai.d.cts",
        "default": "./dist/openai.cjs"
      }
    },
    "./xai": {
      "import": {
        "types": "./dist/xai.d.ts",
        "default": "./dist/xai.js"
      },
      "require": {
        "types": "./dist/xai.d.cts",
        "default": "./dist/xai.cjs"
      }
    },
    "./google": {
      "import": {
        "types": "./dist/google.d.ts",
        "default": "./dist/google.js"
      },
      "require": {
        "types": "./dist/google.d.cts",
        "default": "./dist/google.cjs"
      }
    },
    "./mcp": {
      "import": {
        "types": "./dist/mcp/index.d.ts",
        "default": "./dist/mcp/index.js"
      },
      "require": {
        "types": "./dist/mcp/index.d.cts",
        "default": "./dist/mcp/index.cjs"
      }
    },
    "./mcp/stdio": {
      "import": {
        "types": "./dist/mcp/stdio.d.ts",
        "default": "./dist/mcp/stdio.js"
      },
      "require": {
        "types": "./dist/mcp/stdio.d.cts",
        "default": "./dist/mcp/stdio.cjs"
      }
    },
    "./edge": {
      "import": {
        "types": "./dist/edge.d.ts",
        "default": "./dist/edge.js"
      },
      "require": {
        "types": "./dist/edge.d.cts",
        "default": "./dist/edge.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest run --typecheck.only",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run test:types && npm run build && publint --strict && attw --pack --profile node16",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish",
    "prepare": "tsup",
    "prepublishOnly": "npm run build && publint --strict && attw --pack --profile node16"
  },
  "keywords": [
    "ai",
    "llm",
    "sdk",
    "anthropic",
    "claude",
    "openai",
    "gemini",
    "xai",
    "grok",
    "streaming",
    "edge",
    "agent",
    "tool-calling"
  ],
  "peerDependencies": {
    "zod": "^3.23.0 || ^4.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.0",
    "@changesets/cli": "~2.31.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "msw": "^2.7.0",
    "prettier": "^3.4.0",
    "publint": "^0.3.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.0.0",
    "zod": "^3.23.0"
  }
}
