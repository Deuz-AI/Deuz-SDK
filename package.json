  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:protocol": "vitest run test/stream-protocol.test.ts",
    "test:conformance": "vitest run test/provider-conformance.test.ts",
    "test:browser": "vitest run test/browser-compat.test.ts",
    "test:watch": "vitest",
    "test:types": "vitest run --typecheck.only",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:package": "node tooling/verify-package.mjs && node tooling/run-package-lints.mjs",
    "verify:runtime": "node tooling/check-runtime-compat.mjs",
    "verify:size": "node tooling/check-bundle-size.mjs",
    "verify:api": "node tooling/check-api-contract.mjs",
    "verify:docs": "npm --prefix docs run types:check && npm --prefix docs run build",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run test:types && npm run build && npm run verify:package && npm run verify:runtime && npm run verify:size && npm run verify:api",
    "release:verify": "npm run check && npm run verify:docs",
    "release:publish": "npm run release:verify && changeset publish",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run release:publish",
    "prepare": "tsup",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
