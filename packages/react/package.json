{
  "name": "@deuz-sdk/react",
  "version": "1.8.0",
  "description": "React bindings for the Deuz SDK — useChat/useObject hooks and headless chat components.",
  "license": "MIT",
  "author": "Umutcan Edizaslan (U-C4N)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Deuz-AI/Deuz-SDK.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/Deuz-AI/Deuz-SDK#readme",
  "bugs": "https://github.com/Deuz-AI/Deuz-SDK/issues",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify:package": "publint --strict && attw --pack .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "react",
    "hooks",
    "chat",
    "useChat",
    "streaming",
    "deuz"
  ],
  "peerDependencies": {
    "@deuz-sdk/core": "^1.8.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.0",
    "@deuz-sdk/core": "^1.8.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^29.1.1",
    "publint": "^0.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.0.0"
  }
}
